include ./kitty-themes/themes/Harper.conf
allow_remote_control yes

# Use GTK Theme: https://github.com/kovidgoyal/kitty/issues/2439#issuecomment-1372560759
linux_display_server x11


# BEGIN_KITTY_FONTS
font_family      family="0xProto Nerd Font"
bold_font        auto
italic_font      auto
bold_italic_font auto
# END_KITTY_FONTS
